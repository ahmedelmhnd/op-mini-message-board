<html>
    <head>
        <title><%= title %></title>
    </head>
    <body>
        <ul>
        <% messages.forEach((message, index) => {  %> 
            <li> 
                User: <%= message.user %>, text: <%= message.text %>, Date: <%= message.added %>
                <a href="/message/<%= index %>">Open</a>
            </li>
        <%  }); %>  
        </ul>
        <a href="/new">ADD Entry</a>
    </body>
</html>